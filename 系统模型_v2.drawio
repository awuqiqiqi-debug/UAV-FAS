        <!-- ═══════════════════════════════════════ -->

        <!-- h^U_{U,p} (UAV→Eve) -->
        <mxCell id="ch_ue" value="&lt;i style='font-size:10px;color:#E53935'&gt;h&lt;sup&gt;U&lt;/sup&gt;&lt;sub&gt;U,p&lt;/sub&gt;&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=#FFFFFF;opacity=90;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="555" y="400" width="50" height="20" as="geometry"/>
        </mxCell>

        <!-- h^U_{R,k} (RIS→User) -->
