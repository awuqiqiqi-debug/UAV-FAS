        <!--        窃听者 (耳机图标)                   -->
        <!-- ═══════════════════════════════════════ -->
        <mxCell id="eve_body" value="" style="ellipse;fillColor=#E53935;strokeColor=#B71C1C;strokeWidth=2;gradientColor=#EF5350;gradientDirection=north;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="740" width="60" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="eve_icon" value="&#x1F3A7;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=28;" vertex="1" parent="1">
          <mxGeometry x="533" y="743" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="eve_label" value="&lt;b style='font-size:10px;color:#B71C1C'&gt;Eavesdropper&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="515" y="810" width="90" height="18" as="geometry"/>
        </mxCell>

        <!-- ═══════════════════════════════════════ -->
        <!--         信号路径 (带弧度)                  -->
        <!-- ═══════════════════════════════════════ -->

        <!-- FAS → U1 直射 (蓝色实线) -->
        <mxCell id="sig_u1" value="" style="endArrow=classic;strokeColor=#2196F3;strokeWidth=2.5;exitX=0.1;exitY=1;exitDx=0;exitDy=0;curved=1;shadow=0;" edge="1" parent="1" source="fas_base" target="phone1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="450" y="350"/>
              <mxPoint x="300" y="500"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- FAS → U2 直射 (蓝色实线) -->
        <mxCell id="sig_u2" value="" style="endArrow=classic;strokeColor=#2196F3;strokeWidth=2.5;exitX=0.9;exitY=1;exitDx=0;exitDy=0;curved=1;shadow=0;" edge="1" parent="1" source="fas_base" target="phone2">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1100" y="350"/>
              <mxPoint x="1250" y="500"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- FAS → E 直射 (红色虚线, 窃听) -->
        <mxCell id="sig_eve" value="" style="endArrow=classic;strokeColor=#E53935;strokeWidth=2;dashed=1;dashPattern=10 5;exitX=0.3;exitY=1;exitDx=0;exitDy=0;curved=1;shadow=0;" edge="1" parent="1" source="fas_base" target="eve_body">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="580" y="380"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- FAS → RIS (蓝色实线, 上行) -->
        <mxCell id="sig_ris" value="" style="endArrow=classic;strokeColor=#2196F3;strokeWidth=2.5;exitX=0.4;exitY=1;exitDx=0;exitDy=0;curved=1;shadow=0;" edge="1" parent="1" source="fas_base" target="ris_panel">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- RIS → U1 反射 (蓝色实线) -->
        <mxCell id="ris_u1" value="" style="endArrow=classic;strokeColor=#2196F3;strokeWidth=2.5;exitX=0.1;exitY=0;exitDx=0;exitDy=0;curved=1;shadow=0;" edge="1" parent="1" source="ris_panel" target="phone1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="350" y="480"/>
              <mxPoint x="220" y="600"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- RIS → U2 反射 (蓝色实线) -->
        <mxCell id="ris_u2" value="" style="endArrow=classic;strokeColor=#2196F3;strokeWidth=2.5;exitX=0.9;exitY=0;exitDx=0;exitDy=0;curved=1;shadow=0;" edge="1" parent="1" source="ris_panel" target="phone2">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1100" y="480"/>
              <mxPoint x="1230" y="600"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- RIS → E 干扰 (红色虚线, 人工噪声) -->
        <mxCell id="ris_eve" value="" style="endArrow=classic;strokeColor=#E53935;strokeWidth=2.5;dashed=1;dashPattern=10 5;exitX=0.2;exitY=1;exitDx=0;exitDy=0;curved=1;shadow=0;" edge="1" parent="1" source="ris_panel" target="eve_body">
          <mxGeometry relative="1" as="geometry"/>
